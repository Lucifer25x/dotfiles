# ------------------------------
# ----------- custom -----------
# ------------------------------

# lock the screen
bindsym Mod4+l exec $lock_cmd

# greenclip
exec --no-startup-id greenclip daemon
bindsym $mod+v exec --no-startup-id rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# start terminal 
bindsym $mod+Return exec konsole

# start dmenu
# bindsym $mod+Shift+d exec --no-startup-id "dmenu_run -nf '#F8F8F2' -nb '#282A36' -sb '#6272A4' -sf '#F8F8F2' -fn 'monospace-10' -p 'dmenu%'"

# screenshot
# bindsym Print exec --no-startup-id scrot $HOME/Pictures/Screenshots/`date +%Y-%m-%d_%H%M%S`.png
# bindsym $mod+Print exec --no-startup-id scrot --select $HOME/Pictures/Screenshots/`date +%Y-%m-%d_%H%M%S`.png
bindsym Print exec --no-startup-id spectacle

# start firefox
bindsym $mod+Shift+f exec firefox

# rofi
bindsym $mod+d exec --no-startup-id rofi -show drun

# change keyboard layout
exec_always --no-startup-id setxkbmap -layout us,az -option grp:win_space_toggle

# change brightness ------------
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl --min-val=2 -q set 5%-

# blueman
exec --no-startup-id blueman-applet

# wallpaper
exec --no-startup-id ~/.fehbg

# polybar
exec_always --no-startup-id ~/.config/polybar/launch.sh

# picom
exec --no-startup-id picom -b

# enable touchpad click
exec_always --no-startup-id xinput set-prop "ELAN1203:00 04F3:307A Touchpad" "libinput Tapping Enabled" 1

# enable natural scrolling on touchpad
exec_always --no-startup-id xinput set-prop "ELAN1203:00 04F3:307A Touchpad" "libinput Natural Scrolling Enabled" 1

# decrease pointer speed for the mouse
exec_always --no-startup-id xinput set-prop "ELAN1203:00 04F3:307A Mouse" "libinput Accel Speed" -0.5

# dunst
exec --no-startup-id dunst

# keepassxc
exec --no-startup-id keepassxc --minimized

# gnome keyring
# exec --no-startup-id gnome-keyring-daemon --start --components=secrets

# --------------------------------
# ------------ Other  ------------
# --------------------------------

for_window [class=".*"] border pixel 1
smart_gaps on
gaps inner 2
gaps outer 0
